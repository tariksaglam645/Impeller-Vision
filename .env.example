# ImpellerVision — ortam degiskenleri sablonu
# Bu dosyayi .env olarak kopyalayip degerleri doldurun (.env git'e EKLENMEZ).
#   cp .env.example .env

# --- Ziyaret bildirimi (opsiyonel; bos birakilirsa /track devre disi) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ornek@gmail.com
# Gmail UYGULAMA SIFRESI (https://myaccount.google.com/apppasswords) — normal sifre degil
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM_NAME=ImpellerVision
NOTIFY_TO=ornek@gmail.com
NOTIFY_DEDUPE_SECONDS=21600
